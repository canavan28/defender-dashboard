# ─────────────────────────────────────────────
# Frontend Environment Variables
# Add these in Vercel → your project → Settings → Environment Variables
# ─────────────────────────────────────────────

# Your Railway API server URL (no trailing slash)
# e.g. https://defender-dashboard-api-production.up.railway.app
VITE_API_URL=https://your-railway-app.up.railway.app

# Must match the API_KEY set in Railway
VITE_API_KEY=your_random_api_key_here
